APP_ENV=local
LOG_LEVEL=INFO
MODEL_PROVIDER=mock

# LLM routing
ENABLE_REAL_LLM=false
LLM_DEFAULT_PROVIDER=mock

# Orchestrated path (recommended): YAML llm_routes.yaml + model_registry.yaml + env
# deployment vars below are primary for model selection.
# LLM_ROLE_CONFIG_JSON is LEGACY — used ONLY when ENABLE_ORCHESTRATED_DOUBT_SOLVER=false.
#
# Preferred alias-based legacy JSON (no API keys, no inline deployments):
# LLM_ROLE_CONFIG_JSON={"classifier.default":"doubt_solver_classifier","classifier.strong":"doubt_solver_classifier_strong","math.basic":"openai_gpt_4_1_mini","math.intermediate":"openai_gpt_4_1_mini","math.advanced":"deepseek_v4pro","reasoning.basic":"openai_gpt_4_1_mini","reasoning.intermediate":"openai_o4_mini","reasoning.advanced":"openai_o4_mini","general.default":"openai_gpt_4_1_mini","current_affairs.default":"openai_gpt_4_1_mini","doubt_solver_classifier":"doubt_solver_classifier","doubt_solver_generator":"general_fast_generator"}
#
# Deprecated inline provider format (do not use — stale deployments):
# LLM_ROLE_CONFIG_JSON={"doubt_solver_classifier":{"provider":"azure_openai","model_label":"classifier","deployment":"gpt-4.1-mini","temperature":0,"max_tokens":650,"supports_streaming":false}}
LLM_ROLE_CONFIG_JSON={}

# Orchestrated doubt solver — uses YAML routes/registry (ignores LLM_ROLE_CONFIG_JSON)
ENABLE_ORCHESTRATED_DOUBT_SOLVER=false

# Azure OpenAI (required when provider=azure_openai)
# Endpoint must end with /openai/v1 for azure_foundry_v1 profile.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=

# Azure deployment names — must match Azure portal / Foundry deployment names.
# Public model names (e.g. o4-mini, o3) may NOT equal your deployment name.
# Example: if Azure deployment is named "meritranker-o4-mini", set:
#   AZURE_OPENAI_DEPLOYMENT_O4_MINI=meritranker-o4-mini
AZURE_OPENAI_DEPLOYMENT_GPT_4_1=gpt-4.1
AZURE_OPENAI_DEPLOYMENT_GPT_4_1_MINI=gpt-4.1-mini
AZURE_OPENAI_DEPLOYMENT_O4_MINI=o4-mini
AZURE_OPENAI_DEPLOYMENT_O3=o3
# When true, send reasoning_effort to Azure reasoning models that opt in via
# model_registry send_reasoning_effort. Default false — metadata only.
AZURE_OPENAI_SEND_REASONING_EFFORT=false
# Optional GPT-5.x fallback — leave blank until provisioned in Azure
AZURE_OPENAI_DEPLOYMENT_GPT_5_4=
AZURE_OPENAI_DEPLOYMENT_GPT_5_4_MINI=
AZURE_OPENAI_DEPLOYMENT_GPT_5_5=

# OpenAI native (required when provider=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Bedrock Knowledge Base retrieval (Part 7)
ENABLE_KB_RETRIEVAL=false
BEDROCK_KB_ID=
BEDROCK_KB_REGION=
BEDROCK_KB_MAX_RESULTS=5
BEDROCK_KB_MIN_SCORE=

# DynamoDB record fetch (Part 8)
ENABLE_DYNAMODB_FETCH=false
DYNAMODB_QUESTION_TABLE=
DYNAMODB_PATTERN_TABLE=
DYNAMODB_DEFAULT_INDEX=
DYNAMODB_REGION=

# Context builder (Part 9)
DOUBT_SOLVER_MAX_CONTEXT_CHARS=6000
CONTEXT_TOPIC_HINT_CONFIDENCE_THRESHOLD=0.85
CONTEXT_MAX_RETRIEVAL_TAGS=10
DOUBT_SOLVER_CLASSIFIER_CONFIDENCE_THRESHOLD=0.93

# DeepSeek (optional — provider_not_configured at invoke time if key missing)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_ADVANCED_MODEL=deepseek-reasoner
DEEPSEEK_V4PRO_MODEL=deepseek-reasoner
LLM_ENABLE_DEEPSEEK_ROUTES=false

# Azure-hosted DeepSeek / Azure AI Foundry compatible deployment (optional)
# Inactive unless a route selects a deepseek_azure_* model alias.
# Deployment names must match actual Azure deployment names, not public model names.
AZURE_DEEPSEEK_API_KEY=
AZURE_DEEPSEEK_ENDPOINT=
AZURE_DEEPSEEK_API_VERSION=
AZURE_DEEPSEEK_TIMEOUT_SECONDS=90
AZURE_DEEPSEEK_REASONER_DEPLOYMENT=
AZURE_DEEPSEEK_CHAT_DEPLOYMENT=
AZURE_DEEPSEEK_ADVANCED_DEPLOYMENT=

# Gemini (optional — provider_not_configured at invoke time if key missing)
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_TIMEOUT_SECONDS=30
GEMINI_DEFAULT_MODEL=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-lite
GEMINI_TEXT_MODEL=gemini-2.5-flash
LLM_ENABLE_GEMINI_ROUTES=false

# Generator answer quality (validation + one rewrite on failure)
ANSWER_QUALITY_VALIDATION_ENABLED=true
ANSWER_QUALITY_REWRITE_ENABLED=true
ANSWER_QUALITY_MATH_INTERMEDIATE_MAX_CHARS=2200
ANSWER_QUALITY_MAX_REWRITE_ATTEMPTS=1
ANSWER_QUALITY_MAX_VISIBLE_STEPS=8
ANSWER_QUALITY_MAX_DISPLAY_MATH_BLOCKS=6
ANSWER_QUALITY_MAX_MATH_LINE_CHARS=300

# Web search
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_MAX_CONTEXT_CHARS=2500
WEB_SEARCH_SOURCE_STRICTNESS=authoritative_first
WEB_SEARCH_ALLOW_GENERIC_FALLBACK=false
WEB_SEARCH_ALLOW_EXAM_PREP_FALLBACK=true
WEB_SEARCH_EXAM_PREP_MAX_SELECTED_RESULTS=2
WEB_SEARCH_REQUIRE_OFFICIAL_FOR_EXAM_UPDATES=true
WEB_SEARCH_REQUIRE_TRUSTED_FOR_CURRENT_AFFAIRS=true
WEB_SEARCH_MIN_TRUSTED_RESULTS=1
WEB_SEARCH_DEFAULT_RECENT_DAYS=30
WEB_SEARCH_SEARCH_DEPTH=basic
WEB_SEARCH_MAX_SELECTED_RESULTS=3
WEB_SEARCH_RERANK_MIN_SCORE=0.65
WEB_SEARCH_ENABLE_EXTRACT=false
WEB_SEARCH_EXTRACT_MAX_URLS=2
WEB_SEARCH_EXTRACT_DEPTH=basic

# AWS credentials
AWS_REGION=
